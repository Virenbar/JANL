{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":semanticCommitTypeAll(chore)",
    "schedule:quarterly"
  ],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "groupName": "actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "description": "Skip nuget",
      "matchManagers": [
        "nuget"
      ],
      "enabled": false
    }
  ]
}